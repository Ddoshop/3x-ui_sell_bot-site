# Telegram bot
TELEGRAM_BOT_TOKEN=1234567890:replace_with_your_bot_token
TG_BOT_USERNAME=@your_bot_username
BOT_CHAT_ID=123456789
WEBHOOK_URL=
WEBHOOK_PATH=/bot-webhook
WEBHOOK_PORT=8080
WEBHOOK_FALLBACK_TIMEOUT_MS=30000
WEBHOOK_RETRY_INTERVAL_MS=3600000
WEBHOOK_HEALTH_INTERVAL_MS=30000
BOT_HEARTBEAT_INTERVAL_MS=60000

# Public domains
DOMAIN=guserv.ru
API_DOMAIN=api.guserv.ru

# Internal API URL for the site container
API_URL=http://api-payments:8788

# Branding
BRAND_NAME=VPN Premium
BRAND_EMOJI=🌐

# 3x-ui / XUI
XUI_PANEL_URL=https://46.30.45.211:37163/panel
XUI_PUBLIC_URL=https://guserv.ru
XUI_USERNAME=replace_with_xui_username
XUI_PASSWORD=replace_with_xui_password
XUI_INBOUND_ID=1

# Security
JWT_SECRET=replace_with_long_random_string
ADMIN_PASSWORD=replace_with_admin_password
INTERNAL_API_TOKEN=replace_with_internal_api_token

# Anti-abuse and health
TRIAL_COOLDOWN_MS=2592000000
BOT_HEARTBEAT_STALE_MS=120000
SITE_HEALTH_URL=http://site:3000/health

# Database
DB_PATH=/app/data/db.json

# Runtime
NODE_ENV=production
